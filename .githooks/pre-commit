#!/usr/bin/env bash
# Pre-commit hook: auto-sync .github/instructions/ → .claude/rules/
# Install: git config core.hooksPath .githooks

# Check if any .github/instructions/ files are staged
if git diff --cached --name-only | grep -q '^\.github/instructions/'; then
  echo "Syncing .claude/rules/ from .github/instructions/..."
  make sync-instructions

  # Stage the regenerated files
  git add .claude/rules/*.md
  # But don't stage instruction-sync.md if it wasn't already staged
  git diff --cached --name-only | grep -q '\.claude/rules/instruction-sync\.md' || git reset HEAD .claude/rules/instruction-sync.md 2>/dev/null
fi
